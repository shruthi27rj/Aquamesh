class WaterPipelineSimulator:
    def __init__(self):
        self.G = None
        self.sensor_data = {}
        self.anomaly_probs = {}
        self.reroute_suggestions = {}
    
    def generate_network(self, n_nodes=50, seed=42, density=0.1):
        random.seed(seed)
        np.random.seed(seed)
        
        self.G = nx.grid_2d_graph(8, 8)
        pos = {(i,j): (i*50 + np.random.normal(0,5), j*50 + np.random.normal(0,5)) 
               for i,j in self.G.nodes()}
        
        extra_nodes = max(0, n_nodes - len(self.G.nodes()))
        for i in range(extra_nodes):
            x, y = np.random.uniform(0, 400, 2)
            node_id = f"N{i+64}"
            self.G.add_node(node_id, pos=(x,y))
            distances = [(n, np.linalg.norm(np.array(pos[n]) - np.array([x,y]))) 
                        for n in list(self.G.nodes())[:-extra_nodes+i]]
            distances.sort(key=lambda x: x[1])
            for near_node, dist in distances[:3]:
                if dist < 80:
                    self.G.add_edge(node_id, near_node, capacity=np.random.uniform(10, 50))
        
        for node in self.G.nodes():
            x, y = pos[node]
            self.G.nodes[node].update({
                'pos': (x, y),
                'pressure': np.random.normal(50, 5),
                'ph': np.random.normal(7.2, 0.3)
            })
        
        for u, v, data in self.G.edges(data=True):
            data.update({'capacity': np.random.uniform(20, 100), 'flow': 0})
        
        self.positions = nx.get_node_attributes(self.G, 'pos')
        return self.G
    
    def simulate_step(self, leak_prob=0.05, anomaly_prob=0.1):
        if self.G is None:
            return
        
        step_time = len(self.sensor_data) if self.sensor_data else 0
        
        for node in self.G.nodes():
            base_pressure = self.G.nodes[node]['pressure']
            base_ph = self.G.nodes[node]['ph']
            
            if np.random.random() < leak_prob:
                pressure = base_pressure * np.random.uniform(0.3, 0.7)
                ph = base_ph + np.random.uniform(-1.5, 0.5)
            elif np.random.random() < anomaly_prob:
                pressure = base_pressure * np.random.uniform(1.3, 2.0)
                ph = base_ph + np.random.uniform(-0.8, 1.2)
            else:
                pressure = base_pressure + np.random.normal(0, 2)
                ph = base_ph + np.random.normal(0, 0.1)
            
            self.G.nodes[node]['pressure'] = pressure * 0.95 + base_pressure * 0.05
            self.G.nodes[node]['ph'] = ph * 0.9 + base_ph * 0.1
            
            if node not in self.sensor_data:
                self.sensor_data[node] = {'pressure': [], 'ph': []}
            self.sensor_data[node]['pressure'].append(pressure)
            self.sensor_data[node]['ph'].append(ph)
    
    def train_detect_anomalies(self, steps=10):
        if not self.sensor_data:
            return
        
        X, node_ids = [], []
        for node, data in self.sensor_data.items():
            if len(data['pressure']) >= steps:
                recent_press = data['pressure'][-steps:]
                recent_ph = data['ph'][-steps:]
                press_trend = (recent_press[-1] - recent_press[0]) / steps
                ph_trend = (recent_ph[-1] - recent_ph[0]) / steps
                press_std = np.std(recent_press)
                ph_std = np.std(recent_ph)
                X.append([press_trend, ph_trend, press_std, ph_std])
                node_ids.append(node)
        
        if len(X) < 5:
            return
        
        scaler = StandardScaler()
        X_scaled = scaler.fit_transform(X)
        model = IsolationForest(contamination=0.2, random_state=42)
        preds = model.fit_predict(X_scaled)
        anomaly_scores = model.decision_function(X_scaled)
        probs = 1 / (1 + np.exp(-anomaly_scores * 2))
        self.anomaly_probs = {node: prob for node, prob in zip(node_ids, probs)}
    
    def suggest_rerouting(self):
        if not self.anomaly_probs:
            return
        
        suggestions = {}
        high_risk_nodes = {n: p for n, p in self.anomaly_probs.items() if p > 0.6}
        
        for risky_node, prob in high_risk_nodes.items():
            neighbors = list(self.G.neighbors(risky_node))
            if len(neighbors) > 1:
                best_alt = max(neighbors, key=lambda n: self.G.degree(n))
                suggestions[risky_node] = {'avoid': risky_node, 'reroute_to': best_alt, 'risk': prob}
        
        self.reroute_suggestions = suggestions
        return suggestions

